{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@/components": [
        "src/components/*"
      ],
      "@/hooks": [
        "src/hooks/*"
      ],
      "@/store": [
        "src/store/*"
      ],
      "@/services": [
        "src/services/*"
      ],
      "@/theme": [
        "src/theme/*"
      ],
      "@/types": [
        "src/types/*"
      ],
      "@/utils": [
        "src/utils/*"
      ],
      "@/assets": [
        "src/assets/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
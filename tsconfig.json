{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components": ["src/components"],
      "@/components/*": ["src/components/*"],
      "@/hooks": ["src/hooks"],
      "@/hooks/*": ["src/hooks/*"],
      "@/store": ["src/store"],
      "@/store/*": ["src/store/*"],
      "@/services": ["src/services"],
      "@/services/*": ["src/services/*"],
      "@/theme": ["src/theme"],
      "@/theme/*": ["src/theme/*"],
      "@/types": ["src/types"],
      "@/types/*": ["src/types/*"],
      "@/utils": ["src/utils"],
      "@/utils/*": ["src/utils/*"],
      "@/assets": ["src/assets"],
      "@/assets/*": ["src/assets/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}

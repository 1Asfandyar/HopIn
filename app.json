{
  "expo": {
    "scheme": "hopin",
    "experiments": {
      "typedRoutes": true
    },
    "name": "HopIn",
    "slug": "HopIn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icons/hopin_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/icons/hopin_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16A34A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asfu.hopin"
    },
    "android": {
      "package": "com.asfu.hopin",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icons/hopin_icon.png",
        "backgroundColor": "#16A34A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./src/assets/icons/hopin_icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow HopIn to use your location so we can set your current pickup point."
        }
      ]
    ],
    "extra": {
      "googleMapsApiKey": "AIzaSyDa18ohWW0XLQghZN0ZzXTO_7u5cmBStvw",
      "googlePlacesApiKey": "AIzaSyDa18ohWW0XLQghZN0ZzXTO_7u5cmBStvw",
      "router": {},
      "eas": {
        "projectId": "87817b6f-78f3-43e2-aee5-1be06de296fc"
      }
    }
  }
}

{
  "expo": {
    "scheme": "HopIn",
    "experiments": {
      "typedRoutes": true
    },
    "name": "HopIn",
    "slug": "HopIn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icons/hopin_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/logos/hopin_light.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icons/hopin_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./src/assets/icons/hopin_icon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}

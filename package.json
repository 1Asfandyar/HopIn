    "@react-navigation/native": "^7.0.0",
    "dotenv": "^17.4.2",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "formik": "^2.4.9",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
